# Server
PORT=7001
NODE_ENV=development

# MongoDB (Atlas connection string)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# JWT secrets (use long random strings)
JWT_ACCESS_SECRET=replace_with_long_random_access_secret
JWT_REFRESH_SECRET=replace_with_long_random_refresh_secret

# Redis (Upstash / Redis Cloud). Use rediss:// for TLS.
REDIS_URL=rediss://default:<password>@<host>:<port>

# Allowed frontend origins (comma-separated, no trailing slash)
CLIENT_ORIGIN=http://localhost:5173,https://your-frontend.vercel.app
